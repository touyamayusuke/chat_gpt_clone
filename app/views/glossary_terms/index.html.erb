<div class="min-h-svh bg-background text-foreground">
  <header class="sticky top-0 z-20 border-b border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
      <div class="flex items-center gap-3">
        <%= link_to "← チャットに戻る", root_path, class: "rounded-lg px-3 py-2 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800" %>
        <div>
          <h1 class="text-xl font-semibold">用語管理</h1>
          <p class="text-sm text-zinc-500">AI に渡す説明文をここで登録します。</p>
        </div>
      </div>
    </div>
  </header>

  <div class="mx-auto grid max-w-6xl gap-6 px-4 py-6 lg:grid-cols-[360px_1fr]">
    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
      <h2 class="mb-4 text-lg font-medium">用語を追加</h2>

      <%= form_with model: @glossary_term, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :term, "用語", class: "mb-1 block text-sm font-medium" %>
          <%= form.text_field :term, class: "w-full rounded-xl border border-zinc-300 bg-background px-3 py-2 dark:border-zinc-700", placeholder: "例: RAG" %>
          <% @glossary_term.errors.full_messages_for(:term).each do |message| %>
            <p class="mt-1 text-sm text-red-500"><%= message %></p>
          <% end %>
        </div>

        <div>
          <%= form.label :description, "説明", class: "mb-1 block text-sm font-medium" %>
          <%= form.text_area :description, rows: 6, class: "w-full rounded-xl border border-zinc-300 bg-background px-3 py-2 dark:border-zinc-700", placeholder: "AI に渡したい説明を書きます" %>
          <% @glossary_term.errors.full_messages_for(:description).each do |message| %>
            <p class="mt-1 text-sm text-red-500"><%= message %></p>
          <% end %>
        </div>

        <%= form.submit "登録する", class: "w-full rounded-xl bg-black px-4 py-2 text-white hover:opacity-90 dark:bg-white dark:text-black" %>
      <% end %>
    </section>

    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-medium">登録済みの用語</h2>
        <span class="text-sm text-zinc-500"><%= @glossary_terms.count %>件</span>
      </div>

      <% if @glossary_terms.empty? %>
        <div class="rounded-xl border border-dashed border-zinc-300 px-4 py-8 text-center text-sm text-zinc-500 dark:border-zinc-700">
          まだ用語が登録されていません。
        </div>
      <% else %>
        <div class="space-y-3">
          <% @glossary_terms.each do |glossary_term| %>
            <div class="rounded-xl border border-zinc-200 p-4 dark:border-zinc-800">
              <div class="mb-2 flex items-start justify-between gap-4">
                <div class="text-base font-medium"><%= glossary_term.term %></div>
                <div class="flex items-center gap-2">
                  <%= link_to "編集", edit_glossary_term_path(glossary_term), class: "shrink-0 rounded-lg border border-zinc-300 px-3 py-1 text-sm hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800" %>
                  <%= link_to "削除", delete_modal_glossary_term_path(glossary_term), data: { turbo_stream: true }, class: "shrink-0 rounded-lg border border-red-200 px-3 py-1 text-sm text-red-600 hover:bg-red-50 dark:border-red-900 dark:hover:bg-red-950" %>
                </div>
              </div>
              <p class="whitespace-pre-wrap text-sm leading-6 text-zinc-600 dark:text-zinc-300"><%= glossary_term.description %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    </section>
  </div>
</div>